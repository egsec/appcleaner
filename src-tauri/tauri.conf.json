{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AppCleaner",
  "version": "0.2.0",
  "identifier": "dev.appcleaner.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AppCleaner",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/512x512.png"
    ]
  }
}
